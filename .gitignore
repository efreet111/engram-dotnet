/**/.vs/
/**/bin/
/**/obj/
/*.swp
/.vs/
/dist/
config/mcp/generated/
/publish/
*.user

# Archivo interno de instrucciones para agentes AI
intrusctions.md

# Variables de entorno locales (contienen rutas específicas de cada instalación)
docker/.env

# Secrets y connection strings — NUNCA commitear credenciales
*.env.local
.env.*.local
secrets/

# Project identity — DO NOT ignore .engram-id
# This file contains the UUID v5 project fingerprint and MUST be committed
# so all team members share the same project identity.
# If .engram-id is in .gitignore, team members will have different IDs.
# !.engram-id
*.pem
*.key
*.pfx

# Connection string files (PostgreSQL, etc.)
*.connectionstring
pg-connection.txt
**/connection-string.*

# Test results (TRX, coverage)
*.trx
**/TestResults/
coverage/
*.coverage
coverage.cobertura.xml

# IDE / Editor
.idea/
*.suo
*.sln.ide
.cursor/

# SDD / AI agent temporary artifacts (root-level only — sdd/ changes are tracked)
/.atl/
design.md
design_output.md
design_result.md
dist-cli/

# Engram MCP local memory (per-user runtime state, not project source)
/.engram/

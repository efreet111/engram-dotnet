# ─────────────────────────────────────────────────────────────────────────────
# Engram — Environment Variables
#
# Copiar este archivo a .env y completar los valores:
#   cp .env.example .env
#
# NUNCA commitear el archivo .env (está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL (TrueNAS Apps) ───────────────────────────────────────────────
# Host del PostgreSQL — en TrueNAS SCALE, usar la IP del servidor o
# host.docker.internal (funciona con extra_hosts del compose)
ENGRAM_PG_HOST=host.docker.internal

# Puerto mapeado del PostgreSQL de TrueNAS Apps
# Verificar en Apps → PostgreSQL → Config → Port
ENGRAM_PG_PORT=5432

# Nombre de la base de datos
ENGRAM_PG_DATABASE=engram

# Usuario de PostgreSQL (configurado al crear la app)
ENGRAM_PG_USER=engram

# Password de PostgreSQL (configurado al crear la app)
ENGRAM_PG_PASSWORD=

# ─── Backend Selection ───────────────────────────────────────────────────────
# Valores: postgres (default) | sqlite
ENGRAM_DB_TYPE=postgres

# ─── Opcional ────────────────────────────────────────────────────────────────
# JWT Secret para autenticación (descomentar para habilitar)
# ENGRAM_JWT_SECRET=

# CORS Origins para acceso web
# ENGRAM_CORS_ORIGINS=http://truenas.local:8080
